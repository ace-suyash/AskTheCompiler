# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

PORT=5000
CLIENT_URL=http://localhost:5173

# Get this from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/askthecompiler?retryWrites=true&w=majority

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_string
JWT_EXPIRES_IN=7d

# Get these from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SendGrid — for email notifications (reply alerts, future verification emails)
# Get API key from app.sendgrid.com → Settings → API Keys
# EMAIL_FROM must be a verified sender identity in SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=noreply@askthecompiler.com

MAIL_USER=your_gmailaccount
MAIL_PASS=your_app_password_16charslong_(setup in myaccount.google.com)

# Email verification — SCAFFOLD ONLY, not enforced yet.
# Set to "true" later to require verified email before posting.
EMAIL_VERIFICATION_REQUIRED=false